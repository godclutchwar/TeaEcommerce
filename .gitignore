# Root gitignore for TeaEcommerce

# Backend
backend/target/
backend/.mvn/
backend/*.log
backend/.factorypath
backend/.project
backend/.settings/
backend/bin/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.env
frontend/.env.*
!frontend/.env.production
!frontend/.env.example

# IDEs
.idea/
.vscode/
*.swp
*.swo
*.DS_Store

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Build
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
